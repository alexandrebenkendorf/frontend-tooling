{
  "name": "@alexandrebenkendorf/frontend-tooling",
  "version": "1.0.0",
  "description": "Shared frontend tooling configs",
  "license": "MIT",
  "type": "module",
  "private": false,
  "bin": {
    "frontend-tooling-init": "./scripts/init.mjs"
  },
  "scripts": {
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexandrebenkendorf/frontend-tooling.git"
  },
  "keywords": [
    "eslint",
    "prettier",
    "typescript",
    "frontend",
    "tooling"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "exports": {
    "./eslint": {
      "types": "./eslint/createEslintConfig.d.mts",
      "default": "./eslint/createEslintConfig.mjs"
    },
    "./lint-staged": "./lint-staged/index.mjs",
    "./prettier": "./prettier/index.mjs",
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/node.json": "./tsconfig/node.json",
    "./tsconfig/eslint.json": "./tsconfig/eslint.json"
  },
  "files": [
    ".editorconfig",
    "eslint",
    "lint-staged",
    "prettier",
    "scripts/init.mjs",
    "tsconfig/",
    "README.md"
  ],
  "dependencies": {
    "@eslint/js": "^9.39.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@vitest/eslint-plugin": "^1.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-alias": "1.1.2",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-only-tests": "2.6.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.0.0",
    "prettier-plugin-ejs": "^1.0.3",
    "typescript-eslint": "8.48.1"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "husky": "9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
