{
  "name": "@alexandrebenkendorf/frontend-tooling",
  "version": "1.4.4",
  "description": "Shared frontend tooling configs",
  "license": "MIT",
  "type": "module",
  "private": false,
  "bin": {
    "frontend-tooling-init": "./scripts/init.mjs"
  },
  "scripts": {
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-staged": "lint-staged",
    "test": "vitest run",
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexandrebenkendorf/frontend-tooling.git"
  },
  "keywords": [
    "eslint",
    "prettier",
    "typescript",
    "frontend",
    "tooling"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    "./eslint": {
      "types": "./eslint/createEslintConfig.d.mts",
      "default": "./eslint/createEslintConfig.mjs"
    },
    "./lint-staged": {
      "types": "./lint-staged/index.d.mts",
      "default": "./lint-staged/index.mjs"
    },
    "./prettier": {
      "types": "./prettier/index.d.mts",
      "default": "./prettier/index.mjs"
    },
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/node.json": "./tsconfig/node.json",
    "./tsconfig/eslint.json": "./tsconfig/eslint.json"
  },
  "files": [
    ".editorconfig",
    "eslint",
    "lint-staged",
    "prettier",
    "scripts/init.mjs",
    "scripts/lib/",
    "tsconfig/",
    "CHANGELOG.md",
    "README.md"
  ],
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@eslint/js": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "globals": "^17.5.0"
  },
  "peerDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^9.0.0",
    "prettier-plugin-ejs": "^1.0.3",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0 || ^6.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@trivago/prettier-plugin-sort-imports": {
      "optional": true
    },
    "prettier-plugin-ejs": {
      "optional": true
    },
    "@vitest/eslint-plugin": {
      "optional": true
    },
    "eslint-plugin-jest": {
      "optional": true
    },
    "eslint-plugin-jsx-a11y": {
      "optional": true
    },
    "eslint-plugin-react": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "eslint-plugin-react-refresh": {
      "optional": true
    }
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^9.39.4",
    "prettier-plugin-ejs": "^1.0.3",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
